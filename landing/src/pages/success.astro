---
import Layout from '../layouts/Layout.astro'
import { ReactIcon } from '../components/atoms/ReactIcon'
---

<Layout title="Reserva Confirmada | Con Hilo Depilo">
  <section class='py-24 md:py-32 bg-ui-bg-light min-h-[80vh] flex items-center justify-center relative overflow-hidden'>
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-brand-secondary/10 rounded-full blur-3xl"></div>

    <div class='container max-w-2xl relative z-10'>
      <div class='bg-white p-10 md:p-16 rounded-[3rem] shadow-xl border border-brand-primary/5 flex flex-col items-center text-center gap-8'>
        <div class='w-24 h-24 bg-brand-primary/10 rounded-full flex items-center justify-center'>
          <ReactIcon
            client:load
            name='LuCheckCircle2'
            size={48}
            className='text-brand-primary'
          />
        </div>

        <div class='flex flex-col gap-4'>
          <h1 class='text-3xl md:text-4xl font-black tracking-tight text-ui-text-main'>
            ¡Reserva Confirmada!
          </h1>
          <p class='text-ui-text-muted text-lg leading-relaxed'>
            Tu pago ha sido procesado con éxito y tu cita está agendada. Hemos enviado los detalles a tu correo electrónico.
          </p>
        </div>

        <a
          href='/'
          class='mt-4 bg-brand-primary text-white px-8 py-4 rounded-2xl font-bold uppercase tracking-widest text-xs md:text-sm hover:bg-brand-primary-dark hover:scale-[1.02] active:scale-95 transition-all shadow-md'
        >
          Volver al Inicio
        </a>
      </div>
    </div>
  </section>
</Layout>
