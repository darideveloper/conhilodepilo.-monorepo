---
import HeroSlider from "./HeroSlider";
import heroTreatments from "../../assets/images/hero-treatments.webp";
import heroAcademy from "../../assets/images/hero-academy.webp";
import heroExperience from "../../assets/images/hero-experience.webp";

const slides = [
  {
    badge: "K-Beauty Aesthetics",
    title: "Tratamientos",
    titleAccent: "de Autor",
    description:
      "Precisión y belleza artesanal para realzar tu mirada con la delicadeza de la estética coreana. Cada detalle cuenta en nuestra búsqueda de la armonía facial.",
    primaryCta: { label: "Ver Servicios", href: "#servicios" },
    secondaryCta: { label: "Nuestro Método", href: "#info" },
    image: heroTreatments.src,
    imageAlt: "Tratamiento de cejas de autor",
  },
  {
    badge: "Academia Profesional",
    title: "Formación",
    titleAccent: "Exclusiva",
    description:
      "Aprende nuestras técnicas más demandadas. Cursos presenciales diseñados para perfeccionar tu talento y llevar tu carrera en la estética al siguiente nivel.",
    primaryCta: { label: "Descubrir Cursos", href: "#cursos" },
    secondaryCta: { label: "Ver Resultados", href: "#resultados" },
    image: heroAcademy.src,
    imageAlt: "Formación en estética profesional",
  },
  {
    badge: "Tu Momento",
    title: "Diseña tu",
    titleAccent: "Mirada",
    description:
      "Disfruta de un espacio diseñado para tu bienestar. Reserva tu cita y déjate consentir por especialistas dedicados a resaltar tu belleza natural.",
    primaryCta: { label: "Reservar Cita", href: "#servicios" },
    secondaryCta: { label: "Conocer Más", href: "#info" },
    image: heroExperience.src,
    imageAlt: "Experiencia de diseño de mirada en estudio",
  },
];
---

<section id="hero">
  <HeroSlider slides={slides} client:load />
</section>
